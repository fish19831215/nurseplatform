<script>
function toggleFaq(el) { var item = el.parentElement; item.classList.toggle('active'); }
function submitBooking() {
    var name = document.getElementById("bookName").value.trim();
    var phone = document.getElementById("bookPhone").value.trim();
    var line = document.getElementById("bookLine").value.trim();
    var service = document.getElementById("bookService").value;
    var note = document.getElementById("bookNote").value.trim();
    if(!name || !phone || !service) { alert("請填寫姓名、電話和服務類型"); return; }
    var inquiries = JSON.parse(localStorage.getItem("inquiries") || "[]");
    inquiries.unshift({ id: "i" + Date.now(), name: name, phone: phone, line: line, service: service, note: note, date: new Date().toISOString().split("T")[0], status: "pending" });
    localStorage.setItem("inquiries", JSON.stringify(inquiries));
    alert("預約成功！我們將盡快與您聯繫！");
    document.getElementById("bookName").value = ""; document.getElementById("bookPhone").value = ""; document.getElementById("bookLine").value = ""; document.getElementById("bookService").value = ""; document.getElementById("bookNote").value = "";
}
</script>

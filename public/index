@media (max-width: 1024px) { .hero-inner, .about-grid { grid-template-columns: 1fr; } .features-grid, .services-grid, .reviews-grid, .team-grid { grid-template-columns: 1fr 1fr; } .stats-grid { grid-template-columns: repeat(2, 1fr); } }
